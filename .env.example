# Compartida con sidecar-auth-api y el servidor de auth existente
JWT_SECRET=your_jwt_secret_here
JWT_ISSUER=SideCar.Auth.Api
JWT_AUDIENCE=SideCar.Auth.Clients
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Cadena de conexión a PostgreSQL (hosteado externamente) usada por
# sidecar-auth-api y messaging-worker
POSTGRES_CONNECTION=Host=__HOST__;Port=5432;Database=chatme;Username=__USER__;Password=__PASSWORD__

# Origen permitido para CORS en los ws-nodes
CLIENT_ORIGIN=http://localhost
